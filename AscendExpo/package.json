    "@react-navigation/native-stack": "^7.14.8",
    "expo": "~55.0.8",
    "expo-av": "^16.0.8",
    "expo-blur": "~55.0.10",
    "expo-haptics": "~55.0.9",
    "expo-linear-gradient": "~55.0.9",
    "expo-speech": "~55.0.9",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
