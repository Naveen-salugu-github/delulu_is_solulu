{
  "name": "ascendexpo",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "node ./node_modules/expo/bin/cli start",
    "android": "node ./node_modules/expo/bin/cli start --android",
    "ios": "node ./node_modules/expo/bin/cli start --ios",
    "web": "node ./node_modules/expo/bin/cli start --web",
    "web:lan": "node ./node_modules/expo/bin/cli start --web --host lan --port 8083",
    "web:build": "node ./node_modules/expo/bin/cli export --platform web"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.1.2",
